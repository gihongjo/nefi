# ── 빌드 산출물 ──────────────────────────────────────────
# 루트 레벨 바이너리 (make server, make agent 결과물)
/nefi-server
/nefi-agent

# BPF 오브젝트 파일 (bpf2go 중간 산출물)
# .go 생성 파일(nefitrace_*_bpfel.go)은 커밋됨 — .o 파일만 제외
*.o

# 일반 Go 빌드 출력
bin/
*.exe
*.out

# ── Go 도구 ───────────────────────────────────────────────
vendor/

# 테스트 커버리지
coverage.*
*.coverprofile

# ── IDE / 에디터 ──────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.iml

# ── OS ────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── 환경 설정 (시크릿 포함 가능) ─────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.crt

# ── 프론트엔드 ────────────────────────────────────────────
ui/node_modules/
web/dist/

# ── 개인 노트 / 학습 자료 ─────────────────────────────────
explain_eBPF2Go

# ── Claude Code 로컬 설정 ─────────────────────────────────
.claude/

# ── 임시/로컬 파일 ────────────────────────────────────────
*.log
tmp/
